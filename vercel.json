{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/webhook", "destination": "/api/webhook" }
  ],
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/keepalive", "schedule": "0 6 * * *" }
  ]
}
