# ─────────────────────────────────────────────────────────────
# Spring Village Bot — environment variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# Numeric ID of the private admin group (negative number, e.g. -1001234567890).
# Add the bot to the group, send a message, and read it from getUpdates,
# or use the /whereami command the bot replies with inside a group.
ADMIN_GROUP_ID=

# PostgreSQL / Supabase connection string.
# Supabase: Project Settings -> Database -> Connection string -> "URI"
# (use the connection pooler URI for serverless / Vercel).
# Example: postgresql://postgres:PASSWORD@db.ref.supabase.co:5432/postgres
DATABASE_URL=

# Shared secret used to verify Telegram webhook requests.
# Generate any long random string, e.g. `openssl rand -hex 32`.
WEBHOOK_SECRET=

# Telegram user ID of the owner (full rights: can add/remove admins).
OWNER_TELEGRAM_ID=

# Default interface language (ru or en).
DEFAULT_LANGUAGE=ru

# Emergency phone number shown to guests for urgent cases.
EMERGENCY_PHONE=+7 XXX XXX XX XX

# Public bot username (without @), used to build QR deep links.
PUBLIC_BOT_USERNAME=SpringVillageSupportBot

# ── Optional / deployment ────────────────────────────────────

# Public HTTPS URL of the webhook endpoint (used by scripts/setWebhook.ts).
# Vercel example: https://your-app.vercel.app/api/webhook
# VPS example:    https://bot.example.com/webhook
WEBHOOK_URL=

# Port for the Express webhook server (src/server.ts). Default 8080.
PORT=8080

# Minutes within which a new guest message is grouped into the
# guest's most recent open request instead of opening a new one.
FOLLOWUP_WINDOW_MINUTES=10

# Bnovo Open API «Старт» (read-only occupancy via /occupancy). Optional —
# skipped entirely when unset. Both come from the Bnovo dashboard's
# "API-доступ" page: BNOVO_ACCOUNT_ID is the plain "ID" shown there (e.g.
# 120639), BNOVO_API_KEY is the copyable "API-ключ" string.
BNOVO_API_KEY=
BNOVO_ACCOUNT_ID=
