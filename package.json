{
  "name": "spring-village-bot",
  "version": "1.0.0",
  "description": "Spring Village Telegram Guest Support Bot — guests scan a house QR code and chat privately with staff, admins answer from a private group.",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/migrate.ts",
    "qr": "tsx scripts/generateQr.ts",
    "set-webhook": "tsx scripts/setWebhook.ts",
    "delete-webhook": "tsx scripts/setWebhook.ts delete",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@vercel/node": "^3.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
